# ──────────────────────────────────────────────
# API 키 / 환경 변수 (절대 커밋 금지)
# ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ──────────────────────────────────────────────
# 가상 환경
# ──────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ──────────────────────────────────────────────
# Python 컴파일 캐시
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ──────────────────────────────────────────────
# 생성된 보고서 / 런타임 산출물
# outputs/ 폴더 전체 제외 (단, .gitkeep 은 포함)
# ──────────────────────────────────────────────
outputs/*
!outputs/.gitkeep

# ──────────────────────────────────────────────
# 평가 데이터 (자동 생성 — evaluate.py --create-sample 결과)
# ──────────────────────────────────────────────
evaluation/evaluation/eval_data.json

# ──────────────────────────────────────────────
# macOS 시스템 파일
# ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ──────────────────────────────────────────────
# IDE / 에디터
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ──────────────────────────────────────────────
# 로그 / 임시 파일
# ──────────────────────────────────────────────
*.log
*.tmp
*.bak
